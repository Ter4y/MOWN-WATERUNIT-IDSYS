# MOW Identification App - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Server Port
PORT=3001

# MongoDB Connection
# Use MongoDB Atlas connection string (recommended for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/mow_identification?retryWrites=true&w=majority

# Alternative: Local MongoDB connection
# MONGO_URI=mongodb://localhost:27017/mow_identification

# App Settings
APP_NAME=MOW Identification System
DEFAULT_PASSWORD=ChangeMe@123

# CORS Settings (for frontend domain)
CORS_ORIGIN=*

# Node Environment
NODE_ENV=production
